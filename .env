# ─── Heroic Labs Satori ────────────────────────────────────
# Satori cloud (https://heroiclabs.com/satori). Project provisioned at
# https://quizverse-satori-dev-8bf5.us-east1-b.satoricloud.io.
#
# These map directly to Nakama CLI flags: --satori.url, --satori.api_key_name,
# --satori.api_key, --satori.signing_key. Forwarded through docker-compose
# entrypoint as flags (NOT --runtime.env), because they're consumed by the
# Nakama Go binary itself, not by JS modules.
#
# IMPORTANT: Nakama refuses to start if SATORI_URL is set but signing_key is
# blank. Get the signing key from the Satori console (Project → Settings →
# Signing Keys). Until you fill SATORI_SIGNING_KEY below, leave SATORI_URL
# empty so Nakama boots without Satori (the eventsPublish() fan-out then
# becomes a no-op via try/catch in analytics.js — no events go to Satori
# but the in-house dashboard still works).
SATORI_URL=https://quizverse-satori-dev-8bf5.us-east1-b.satoricloud.io
SATORI_API_KEY_NAME=SATORIAPIKEY
SATORI_API_KEY=f6554c37-e40f-490f-b730-acaf6ecabe4c
# Heroic Labs Satori UI calls this "Server Key" (Settings → Server Keys).
# Name in the UI: "nakamaprod". Used by Nakama as the HMAC-SHA256 secret to
# sign Satori session tokens (internal/satori/satori.go:240). Satori
# re-verifies with the same key.
SATORI_SIGNING_KEY=a939cfcc-5ef2-456a-b009-cca2dcc907d2
# Worst-case latency added to analytics_log_event RPC when Satori is slow/down.
# 2000ms keeps Unity clients responsive even during a Satori incident.
SATORI_HTTP_TIMEOUT_MS=2000

