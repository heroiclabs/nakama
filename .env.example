# Nakama Runtime Path
# Default: data/modules (loads old index.js for production safety)
# Set to: data/modules/build (loads new TypeScript build with Hiro+Satori)
NAKAMA_RUNTIME_PATH=data/modules

# API Keys (required by existing production RPCs)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=

# Quests Economy Bridge (used by global wallet, daily rewards sync, mission sync)
QUESTS_ECONOMY_API_URL=http://localhost:3001
NAKAMA_WEBHOOK_SECRET=
DEFAULT_GAME_ID=f6f7fe36-03de-43b8-8b5d-1a1892da4eed
