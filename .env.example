# Nakama Runtime Path
# Default: data/modules (loads old index.js for production safety)
# Set to: data/modules/build (loads new TypeScript build with Hiro+Satori)
NAKAMA_RUNTIME_PATH=data/modules

# API Keys (required by existing production RPCs)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# News Quiz API Keys (server-side only — never in client code)
# GNews free tier: 100 req/day, 31 countries. Server caches 6h to stay within budget.
GNEWS_API_KEY=
# Currents API — 1,000 req/day free, 70+ countries. Best geo gap filler.
# Sign up: https://currentsapi.services/en/register
CURRENTS_API_KEY=
# MediaStack — 500 req/MONTH free, 50+ countries (Middle East, Africa, SE Asia).
# Sign up: https://mediastack.com/signup/free
MEDIASTACK_API_KEY=
# NewsAPI — 100 req/day free, 54 countries. English headline fallback.
NEWSAPI_API_KEY=

# ─── LLM Providers (powers ai_player.js + chatbox/chatbox.js) ─────────────────
# LLM_PROVIDER selects the active provider; chatbox/ai_player fall back across
# the remaining providers if the preferred one's key is empty.
#   claude  -> Anthropic Claude (recommended for chat quality + cost)
#   openai  -> OpenAI gpt-4o-mini (fastest)
#   xai     -> xAI Grok
# At least ONE key must be set or every LLM RPC will return:
#   { success:false, error:"No LLM API key configured." }
# and the Unity ChatBox will fall back to canned replies.
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=

# Quests Economy Bridge (used by global wallet, daily rewards sync, mission sync)
QUESTS_ECONOMY_API_URL=http://localhost:3001
# Set this to whatever value you put in RevenueCat → Webhooks → Authorization header.
# Default hardcoded in docker-compose.yml: ivx-qv-rc-webhook-a7f3d9e2b8c1456f
# Override here only if you want a different value.
NAKAMA_WEBHOOK_SECRET=ivx-qv-rc-webhook-a7f3d9e2b8c1456f
DEFAULT_GAME_ID=126bf539-dae2-4bcf-964d-316c0fa1f92b

# ─── UserMgmt Sync (Nakama → Intelliverse-X-UserManagement) ───────────────────
# Mirrors profile updates (username, firstName, lastName, age, phoneNumber)
# from the rpc_update_player_metadata / rpc_change_username RPCs into
# UserMgmt's PUT /api/user/user/profile endpoint.
#
# The user's Cognito access token is forwarded in the Authorization header,
# so UserMgmt validates the request against the actual end-user — Nakama does
# not need UserMgmt admin credentials for this flow.
#
# Defaults are hardcoded in src/legacy/usermgmt-sync.ts and ship enabled
# pointing at https://api.intelli-verse-x.ai. The variables below are OPTIONAL
# overrides:
#   USERMGMT_SYNC_ENABLED=false   to turn the feature off in an environment
#   USERMGMT_API_BASE_URL=...     to point at a non-prod UserMgmt (staging/dev)
# USERMGMT_SYNC_ENABLED=
# USERMGMT_API_BASE_URL=

# External Analytics - Appodeal
APPODEAL_API_KEY=
APPODEAL_USER_ID=

# External Analytics - Unity Technologies
UNITY_KEY_ID=
UNITY_SECRET_KEY=
UNITY_AUTH_HEADER=

# External Analytics - Apple App Store Connect
# APPLE_PRIVATE_KEY is the .p8 file content — paste the full key including -----BEGIN/END----- lines.
# Apple App ID: 6752571885  |  Vendor Number: 93424228 (financial reports only, not needed in code)
APPLE_KEY_ID=
APPLE_ISSUER_ID=
APPLE_PRIVATE_KEY=

# ─── Heroic Labs Satori ────────────────────────────────────
# Cloud analytics + live-ops product. Provision at https://heroiclabs.com/satori.
# Mapped to --satori.* CLI flags by docker-compose.yml entrypoint.
# Leave SATORI_URL blank to disable the integration (eventsPublish() becomes a
# no-op; in-house analytics dashboard still works).
SATORI_URL=
SATORI_API_KEY_NAME=
SATORI_API_KEY=
SATORI_SIGNING_KEY=
SATORI_HTTP_TIMEOUT_MS=2000

# ─── AWS S3 Asset Storage ──────────────────────────────────────────────────────
# Used by s3_assets module for secure asset delivery (character images, quiz media).
# Create an S3 bucket with private ACL and generate IAM credentials with:
#   - s3:PutObject, s3:GetObject, s3:ListBucket permissions
# See docs/AWS_S3_ASSET_SETUP.md for step-by-step instructions.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=intelliverse-x-assets
# Pre-signed URL expiry (seconds). Default: 1 hour. Max recommended: 24 hours.
AWS_PRESIGNED_URL_EXPIRY=3600

# ─── Analytics Dashboard Admin Auth ───────────────────────────────────────────
# Used by the new admin_login RPC (data/modules/analytics_admin/analytics_admin.js).
# Without these set, the dashboard cannot authenticate and Events/Storage tabs
# will stay broken. Generate the bcrypt hash locally — never commit the plaintext.
#   htpasswd -bnBC 12 "" 'your-password-here' | tr -d ':\n'
#   (or: htpasswd -nbBC 12 "" 'your-password-here' | cut -d: -f2)
ADMIN_USERNAME=ivx-admin
ADMIN_PASSWORD_HASH=
# Plaintext password for the admin-dashboard proxy auto-login only (server-side).
# Never commit this value. Required when ADMIN_DASHBOARD_AUTO_LOGIN=true (default).
ADMIN_PASSWORD=
# Set to false to disable silent auto-login and require the manual login form.
ADMIN_DASHBOARD_AUTO_LOGIN=true
# Optional: shared-secret fallback for server-to-server dashboard calls (CI / scripts).
# Generate: openssl rand -hex 32
DASHBOARD_SECRET=

# ─── Push Notifications ─────────────────────────────────────────────────────
# AWS Lambda endpoints for token registration and push delivery (SNS wrapper).
# See lambda-functions/register-endpoint/ and lambda-functions/send-push/.
PUSH_REGISTER_URL=
PUSH_SEND_URL=
# Firebase project ID used when the client does not supply one.
DEFAULT_FCM_PROJECT_ID=

# ─── Geo-Aware Quiz APIs ─────────────────────────────────────────────────────
# Movies: iTunes RSS feed (https://itunes.apple.com/{cc}/rss/topmovies/limit=50/json)
#   → 100% free, no API key, no sign-up, Apple public API. Country-specific top movies.
# Music:  Deezer API (https://api.deezer.com/chart/0/artists)
#   → 100% free, no API key, no sign-up. Global + country-genre search.
# No environment variables needed for either service.
