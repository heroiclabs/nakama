{
  "mcpServers": {
    "nakama-prod": {
      "command": "npx",
      "args": [
        "tsx",
        "mcp-server/src/index.ts"
      ],
      "env": {
        "NAKAMA_CONSOLE_URL": "https://nakama.intelli-verse-x.ai",
        "NAKAMA_API_URL": "https://nakama.intelli-verse-x.ai",
        "NAKAMA_CONSOLE_USER": "admin",
        "NAKAMA_CONSOLE_PASSWORD": "password",
        "NAKAMA_HTTP_KEY": "defaulthttpkey"
      }
    }
  }
}